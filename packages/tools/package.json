{
  "name": "@manifest-editor/tools",
  "version": "2.0.2",
  "type": "module",
  "bugs": "https://github.com/digirati-co-uk/iiif-manifest-editor/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/digirati-co-uk/iiif-manifest-editor.git",
    "directory": "packages/tools"
  },
  "engines": {
    "node": ">=18.14.1"
  },
  "keywords": [
    "iiif",
    "editor",
    "tools",
    "llm",
    "typescript"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown src/index.ts",
    "dev": "tsdown src/index.ts --watch",
    "lint": "publint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "tsdown src/index.ts"
  },
  "dependencies": {
    "@iiif/helpers": "catalog:",
    "@iiif/parser": "catalog:",
    "@iiif/presentation-3": "^2.2.3",
    "@manifest-editor/creator-api": "workspace:*",
    "@manifest-editor/editor-api": "workspace:*"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "tsdown": "0.16.4",
    "vitest": "v3.0.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
